{
	"servers": {
		"mcp-obsidian": {
			"type": "stdio",
			"command": "uv",
			"args": [
				"--directory",
				"${env:USERPROFILE}/Dropbox/Obsidian/mcp-obsidian",
				"run",
				"mcp-obsidian"
			]
		},
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp@latest"
			],
			"type": "stdio"
		},
		"io.github.ChromeDevTools/chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@0.18.1"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.18.1"
		},
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp@0.0.1a4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"stata-mcp": {
			"type": "http",
			"url": "http://localhost:4000/mcp-streamable"
		}
	},
	"inputs": [
		{
			"id": "OPENAI_API_KEY",
			"type": "promptString",
			"description": "OpenAI API Key (get from https://platform.openai.com/api-keys) — used by SS-Imager for gpt-image-1",
			"password": true
		},
		{
			"id": "firecrawl_api_key",
			"type": "promptString",
			"description": "Firecrawl API Key (get from https://www.firecrawl.dev/app/api-keys)",
			"password": true
		},
		{
			"id": "memory_file_path",
			"type": "promptString",
			"description": "Path to the memory storage file",
			"password": false
		},
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		}
	]
}